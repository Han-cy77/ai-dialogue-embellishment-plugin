{
  "manifest_version": 3,
  "name": "AI-Dialogue-Embellishment-Plugin",
  "version": "1.0.0",
  "description": "AI 对话润色插件 - 帮助优化和润色 AI 对话内容",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"

  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]

}
